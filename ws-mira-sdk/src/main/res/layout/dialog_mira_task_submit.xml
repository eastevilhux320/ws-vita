<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="dialog"
            type="com.wangshu.mira.view.dialog.MiraTaskSubmitResultDialog" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_mira_dialog_base">

        <TextView
            android:id="@+id/tv_mira_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Title"
            android:text="@string/mira_dialog_title_task_submit"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/dp_10"/>

        <TextView
            android:id="@+id/tv_mira_dialog_message"
            android:layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Normal"
            app:layout_constraintTop_toBottomOf="@id/tv_mira_dialog_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginLeft="@dimen/dp_15"
            android:layout_marginRight="@dimen/dp_15"
            android:gravity="left|top"
            android:text="@string/mira_task_submit_message_tips"
            app:layout_constraintBottom_toTopOf="@id/cl_mira_task_submit_result_bottom"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_mira_task_submit_result_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_marginLeft="@dimen/dp_30"
            android:layout_marginRight="@dimen/dp_30">

            <TextView
                android:id="@+id/tv_mira_submit_result_watch"
                android:layout_width="@dimen/dp_0"
                android:layout_height="@dimen/dp_40"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                style="@style/AppTextTheme.Normal"
                android:text="@string/mira_task_submit_watch_detail"
                app:layout_constraintEnd_toStartOf="@id/tv_mira_submit_result_goon"
                app:layout_constraintHorizontal_weight="0.32"
                android:background="@drawable/bg_mira_task_submit_result_watch_detail"
                android:onClick="@{dialog.onViewClick}"/>

            <TextView
                android:id="@+id/tv_mira_submit_result_goon"
                android:layout_width="@dimen/dp_0"
                android:layout_height="@dimen/dp_40"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/AppTextTheme.Normal"
                app:layout_constraintHorizontal_weight="0.68"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_mira_submit_result_watch"
                android:text="@string/mira_task_submit_do_task_goon"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginLeft="@dimen/dp_10"
                android:onClick="@{dialog.onViewClick}"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
