<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="miraTask"
            type="com.wangshu.mira.entity.TaskEntity" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_70">

        <ImageView
            android:id="@+id/iv_mira_task_icon"
            android:layout_width="@dimen/dp_50"
            android:layout_height="@dimen/dp_50"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginLeft="@dimen/dp_10"/>

        <TextView
            android:id="@+id/tv_mira_task_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Title"
            app:layout_constraintTop_toTopOf="@id/iv_mira_task_icon"
            app:layout_constraintStart_toEndOf="@id/iv_mira_task_icon"
            app:layout_constraintBottom_toTopOf="@id/cl_mira_task_tips"
            android:layout_marginLeft="@dimen/dp_10"/>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_mira_task_tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tv_mira_task_title"
            app:layout_constraintStart_toEndOf="@id/iv_mira_task_icon"
            app:layout_constraintBottom_toBottomOf="@id/iv_mira_task_icon"
            android:layout_marginLeft="@dimen/dp_10">

            <androidx.constraintlayout.utils.widget.ImageFilterView
                android:id="@+id/iv_mira_task_app_icon"
                android:layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"
                app:round="@dimen/dp_7"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_mira_task_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AppTextTheme.Normal"
                android:textColor="@color/base_text_hint"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_mira_task_app_icon"
                android:layout_marginLeft="@dimen/dp_2"
                android:textSize="@dimen/sp_11"/>


            <TextView
                android:id="@+id/tv_mira_task_operation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AppTextTheme.Normal"
                android:textSize="@dimen/sp_11"
                android:background="@drawable/bg_mira_task_operation"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginLeft="@dimen/dp_10"
                app:layout_constraintBottom_toBottomOf="parent"
                android:paddingLeft="@dimen/dp_5"
                android:paddingRight="@dimen/dp_5"
                android:paddingTop="@dimen/dp_3"
                android:paddingBottom="@dimen/dp_3"
                app:layout_constraintStart_toEndOf="@id/tv_mira_task_app_name"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_mira_task_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginRight="@dimen/dp_15"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
