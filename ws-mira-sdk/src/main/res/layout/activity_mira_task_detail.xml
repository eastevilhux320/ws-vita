<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.wangshu.mira.model.detail.TaskDetailViewModel" />

        <variable
            name="activity"
            type="com.wangshu.mira.model.detail.TaskDetailActivity" />

        <variable
            name="stepAdapter"
            type="com.wangshu.mira.adapter.TaskStepAdapter" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_base_bg">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_main_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_mira_task_detail_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:src="@drawable/ic_ws_base_back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:padding="@dimen/dp_10"
                android:layout_marginLeft="@dimen/dp_5"/>

            <TextView
                android:id="@+id/tv_mira_task_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AppTextTheme.Title"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="@color/white"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.wangshu.mira.view.FixedNestedScrollView
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0"
            app:layout_constraintTop_toBottomOf="@id/cl_main_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/cl_mira_task_bottom"
            android:focusableInTouchMode="true"
            android:descendantFocusability="blocksDescendants">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_10"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_mira_task_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_mira_task_card"
                    android:elevation="4dp"
                    android:clipToPadding="false"
                    android:outlineProvider="background"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginLeft="@dimen/dp_15"
                    android:layout_marginRight="@dimen/dp_15"
                    android:layout_marginTop="@dimen/dp_5">

                    <androidx.constraintlayout.utils.widget.ImageFilterView
                        android:id="@+id/iv_mira_task_icon"
                        android:layout_width="@dimen/dp_60"
                        android:layout_height="@dimen/dp_60"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="@dimen/dp_10"
                        android:layout_marginLeft="@dimen/dp_10"/>


                    <TextView
                        android:id="@+id/tv_mira_task_name"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Title"
                        android:text="@{viewModel.task.title}"
                        app:layout_constraintTop_toTopOf="@id/iv_mira_task_icon"
                        app:layout_constraintStart_toEndOf="@id/iv_mira_task_icon"
                        android:layout_marginLeft="@dimen/dp_5"
                        app:layout_constraintEnd_toStartOf="@id/tv_mira_task_reward"
                        android:gravity="left|top"
                        android:layout_marginRight="@dimen/dp_5"
                        android:layout_marginTop="@dimen/dp_5"/>

                    <TextView
                        android:id="@+id/tv_mira_task_reward"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Normal"
                        android:text="@{viewModel.task.showPrice}"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginRight="@dimen/dp_5"/>

                    <androidx.constraintlayout.utils.widget.ImageFilterView
                        android:id="@+id/iv_mira_task_app_icon"
                        android:layout_width="@dimen/dp_16"
                        android:layout_height="@dimen/dp_16"
                        app:round="@dimen/dp_8"
                        android:layout_marginLeft="@dimen/dp_5"
                        app:layout_constraintBottom_toBottomOf="@id/iv_mira_task_icon"
                        app:layout_constraintStart_toEndOf="@id/iv_mira_task_icon"
                        android:layout_marginBottom="@dimen/dp_3"/>

                    <TextView
                        android:id="@+id/tv_mira_task_app_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Normal"
                        android:text="@{viewModel.targetApp.appName}"
                        app:layout_constraintTop_toTopOf="@id/iv_mira_task_app_icon"
                        app:layout_constraintBottom_toBottomOf="@id/iv_mira_task_app_icon"
                        app:layout_constraintStart_toEndOf="@id/iv_mira_task_app_icon"
                        android:layout_marginLeft="@dimen/dp_3" />

                    <TextView
                        android:id="@+id/tv_mira_task_operation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Normal"
                        android:textSize="@dimen/sp_11"
                        android:background="@drawable/bg_mira_task_operation"
                        app:layout_constraintTop_toTopOf="@id/tv_mira_task_app_name"
                        android:layout_marginLeft="@dimen/dp_10"
                        app:layout_constraintBottom_toBottomOf="@id/tv_mira_task_app_name"
                        android:paddingLeft="@dimen/dp_5"
                        android:paddingRight="@dimen/dp_5"
                        android:paddingTop="@dimen/dp_2"
                        android:paddingBottom="@dimen/dp_2"
                        app:layout_constraintStart_toEndOf="@id/tv_mira_task_app_name"/>

                    <TextView
                        android:id="@+id/tv_mira_task_line_1"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_1"
                        app:layout_constraintTop_toBottomOf="@id/iv_mira_task_icon"
                        android:background="@color/color_base_line"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/dp_10"/>

                    <TextView
                        android:id="@+id/tv_mira_task_info"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Normal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:gravity="left|top"
                        android:text="@{viewModel.task.introduction}"
                        app:layout_constraintTop_toBottomOf="@id/tv_mira_task_line_1"
                        android:layout_marginTop="@dimen/dp_10"
                        android:paddingLeft="@dimen/dp_10"
                        android:paddingRight="@dimen/dp_10"
                        android:paddingBottom="@dimen/dp_12"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_mira_task_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_mira_task_card"
                    android:elevation="4dp"
                    android:clipToPadding="false"
                    android:outlineProvider="background"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginLeft="@dimen/dp_15"
                    android:layout_marginRight="@dimen/dp_15"
                    android:layout_marginTop="@dimen/dp_5"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:adapter="@{stepAdapter}"
                    android:nestedScrollingEnabled="false"/>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_20"/>

            </LinearLayout>

        </com.wangshu.mira.view.FixedNestedScrollView>

        <LinearLayout
            android:id="@+id/cl_mira_task_bottom"
            android:layout_width="@dimen/dp_0"
            android:layout_height="@dimen/dp_50"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@color/color_base_bg"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/dp_10"
            android:paddingRight="@dimen/dp_10">


            <LinearLayout
                android:id="@+id/ll_task_operation_main"
                android:layout_width="@dimen/dp_0"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tv_task_continue_task"
                android:orientation="vertical"
                android:layout_weight="3"
                android:gravity="center"
                android:onClick="@{activity.onViewClick}"
                android:layout_marginLeft="@dimen/dp_5"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginBottom="@dimen/dp_5">

                <TextView
                    android:id="@+id/tv_mira_task_opeation_main"
                    style="@style/AppTextTheme.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@{viewModel.mainButtonText}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_mira_task_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/AppTextTheme.Normal"
                    android:text="@{viewModel.expirationTimeText}"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_task_continue_task"
                android:layout_width="@dimen/dp_0"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ll_task_operation_main"
                app:layout_constraintEnd_toStartOf="@id/tv_task_operation_sub"
                style="@style/AppTextTheme.Normal"
                android:text="@string/mira_task_continue_task"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:background="@drawable/bg_mira_task_operation_main_continue"
                android:onClick="@{activity.onViewClick}"
                android:layout_marginLeft="@dimen/dp_2"
                android:layout_marginRight="@dimen/dp_2"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginBottom="@dimen/dp_5"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_task_operation_sub"
                android:layout_width="@dimen/dp_0"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ll_task_operation_main"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="@drawable/bg_mira_task_suboperation_main_cancel"
                style="@style/AppTextTheme.Normal"
                android:text="@{viewModel.subButtonText}"
                android:layout_weight="1"
                android:onClick="@{activity.onViewClick}"
                android:layout_marginLeft="@dimen/dp_2"
                android:layout_marginRight="@dimen/dp_2"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginBottom="@dimen/dp_5"
                android:visibility="gone"/>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
