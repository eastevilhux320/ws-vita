<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.wangshu.textus.note.model.main.mine.MineViewModel" />

        <variable
            name="fragment"
            type="com.wangshu.textus.note.model.main.mine.MineFragment" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/cl_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_vip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/AppFragment_CollapsingToolbarLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:contentScrim="?attr/colorPrimary"
                app:layout_scrollFlags="scroll|exitUntilCollapsed">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.8">

                    <ImageView
                        android:id="@+id/iv_account_header"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_160"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:scaleType="fitXY"
                        app:appSrc="@{viewModel.accountCenter.account.headerBackgroundIcon}"/>

                    <ImageView
                        android:id="@+id/iv_mine_account_icon"
                        android:layout_width="@dimen/dp_50"
                        android:layout_height="@dimen/dp_50"
                        app:appSrc="@{viewModel.accountCenter.account.userIcon}"
                        app:layout_constraintTop_toTopOf="@id/iv_account_header"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginTop="@dimen/dp_30"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:onClick="@{fragment.onViewClick}"/>

                    <TextView
                        android:id="@+id/tv_account_nickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Normal"
                        app:appText="@{viewModel.accountCenter.account.nickName}"
                        app:layout_constraintTop_toTopOf="@id/iv_mine_account_icon"
                        app:layout_constraintStart_toEndOf="@id/iv_mine_account_icon"
                        android:layout_marginLeft="@dimen/dp_7"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tv_account_userno"
                        android:onClick="@{fragment.onViewClick}"/>

                    <TextView
                        android:id="@+id/tv_account_userno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/AppTextTheme.Normal"
                        app:appText="@{viewModel.accountCenter.account.userNoText}"
                        app:layout_constraintTop_toBottomOf="@id/tv_account_nickname"
                        app:layout_constraintBottom_toBottomOf="@id/iv_mine_account_icon"
                        app:layout_constraintStart_toEndOf="@id/iv_mine_account_icon"
                        android:layout_marginLeft="@dimen/dp_7"
                        android:textColor="@color/white"
                        android:onClick="@{fragment.onViewClick}"/>


                    <ImageView
                        android:id="@+id/iv_mine_account_arrow"
                        android:layout_width="@dimen/dp_15"
                        android:layout_height="@dimen/dp_15"
                        android:src="@drawable/wsui_ic_va_arrow_white"
                        app:layout_constraintTop_toTopOf="@id/iv_mine_account_icon"
                        app:layout_constraintBottom_toBottomOf="@id/iv_mine_account_icon"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginRight="@dimen/dp_20"
                        android:onClick="@{fragment.onViewClick}"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar_vip"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_80"
                    android:background="@color/color_main_theme"
                    app:layout_collapseMode="pin"
                    android:paddingTop="@dimen/dp_32">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/tv_mine_account_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginLeft="@dimen/dp_15"
                            android:text="@{viewModel.accountCenter.account.nickName}"
                            android:onClick="@{fragment.onViewClick}"/>


                        <ImageView
                            android:id="@+id/iv_mine_setting"
                            android:layout_width="@dimen/dp_30"
                            android:layout_height="@dimen/dp_30"
                            android:padding="@dimen/dp_5"
                            android:src="@drawable/ic_va_mine_setting"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_mine_msg"
                            android:layout_marginRight="@dimen/dp_8"
                            android:onClick="@{fragment.onViewClick}"/>

                        <ImageView
                            android:id="@+id/iv_mine_msg"
                            android:layout_width="@dimen/dp_30"
                            android:layout_height="@dimen/dp_30"
                            android:padding="@dimen/dp_5"
                            android:src="@drawable/ic_va_mine_msg"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginRight="@dimen/dp_10" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.appcompat.widget.Toolbar>

            </com.google.android.material.appbar.CollapsingToolbarLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refreshlayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            android:background="@color/color_app_main_bg">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/dp_10"
                    android:gravity="center_vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_assets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_fillet_white_8"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginRight="@dimen/dp_15"
                        android:layout_marginTop="@dimen/dp_10">

                        <TextView
                            android:id="@+id/tv_mine_assets_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@string/app_mine_assets"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginTop="@dimen/dp_10"
                            android:layout_marginLeft="@dimen/dp_15" />


                        <TextView
                            android:id="@+id/tv_assets_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            app:noteBigDecimal="@{viewModel.assets.balance}"
                            app:layout_constraintTop_toTopOf="@id/tv_assets_integral"
                            app:layout_constraintBottom_toBottomOf="@id/tv_assets_integral"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginRight="@dimen/dp_20"
                            android:textSize="@dimen/sp_14"
                            app:layout_constraintEnd_toStartOf="@id/tv_assets_integral"/>

                        <TextView
                            android:id="@+id/tv_assets_balance_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@string/mime_assets_assets_balance"
                            app:layout_constraintTop_toTopOf="@id/tv_assets_integral_text"
                            app:layout_constraintBottom_toBottomOf="@id/tv_assets_integral_text"
                            app:layout_constraintStart_toStartOf="@id/tv_assets_balance"
                            app:layout_constraintEnd_toEndOf="@id/tv_assets_balance"/>

                        <TextView
                            android:id="@+id/tv_assets_integral"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@{viewModel.assets.integralText}"
                            app:layout_constraintTop_toBottomOf="@id/tv_mine_assets_text"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginTop="@dimen/dp_15"
                            android:textSize="@dimen/sp_14"/>

                        <TextView
                            android:id="@+id/tv_assets_integral_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@string/mime_assets_integral"
                            app:layout_constraintTop_toBottomOf="@id/tv_assets_integral"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginBottom="@dimen/dp_15"
                            android:layout_marginTop="@dimen/dp_2"
                            app:layout_constraintStart_toStartOf="@id/tv_assets_integral"
                            app:layout_constraintEnd_toEndOf="@id/tv_assets_integral"/>


                        <TextView
                            android:id="@+id/tv_assets_coupon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:textSize="@dimen/sp_14"
                            app:textIntString="@{viewModel.assets.couponNum}"
                            app:layout_constraintTop_toTopOf="@id/tv_assets_integral"
                            app:layout_constraintBottom_toBottomOf="@id/tv_assets_integral"
                            app:layout_constraintStart_toEndOf="@id/tv_assets_integral"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginLeft="@dimen/dp_20"/>

                        <TextView
                            android:id="@+id/tv_assets_coupon_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@string/mine_assets_coupon"
                            app:layout_constraintTop_toTopOf="@id/tv_assets_balance_text"
                            app:layout_constraintBottom_toBottomOf="@id/tv_assets_balance_text"
                            app:layout_constraintStart_toStartOf="@id/tv_assets_coupon"
                            app:layout_constraintEnd_toEndOf="@id/tv_assets_coupon"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_budget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_fillet_white_8"
                        android:layout_marginTop="@dimen/dp_10"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginRight="@dimen/dp_15">

                        <TextView
                            android:id="@+id/tv_budget_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@{viewModel.monthBudget.budgetName}"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginTop="@dimen/dp_10"
                            android:layout_marginLeft="@dimen/dp_12"
                            app:layout_constraintBottom_toTopOf="@id/percent_view"/>

                        <TextView
                            android:id="@+id/tv_mine_budget_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:text="@{viewModel.monthBudget.usedPercentageText}"
                            app:layout_constraintTop_toTopOf="@id/tv_budget_name"
                            app:layout_constraintBottom_toBottomOf="@id/tv_budget_name"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginRight="@dimen/dp_10"/>

                        <com.wsvita.ui.view.CirclePercentView
                            android:id="@+id/percent_view"
                            android:layout_width="@dimen/dp_100"
                            android:layout_height="@dimen/dp_100"
                            app:layout_constraintTop_toBottomOf="@id/tv_budget_name"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginTop="@dimen/dp_10"
                            android:layout_marginBottom="@dimen/dp_10"
                            android:layout_marginLeft="@dimen/dp_15"
                            app:circle_nor_color="@color/color_bill_expenditure"
                            app:circle_percent_color="@color/color_money"
                            app:percent_text_size="@dimen/sp_14"
                            app:percent="@{viewModel.monthBudget.percent}"
                            app:percent_digit="2"
                            app:tips_text="@string/budget_used"
                            app:tips_text_size="@dimen/sp_12"
                            app:percent_text_color="@color/color_bill_expenditure" />


                        <TextView
                            android:id="@+id/tv_budget_remining_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="@id/percent_view"
                            app:layout_constraintStart_toEndOf="@id/percent_view"
                            style="@style/AppTextTheme.Normal"
                            android:text="@string/remaining_amount"
                            android:layout_marginLeft="@dimen/dp_15"
                            android:layout_marginTop="@dimen/dp_7"
                            android:textSize="@dimen/sp_14"
                            android:textColor="@color/color_money"/>

                        <TextView
                            android:id="@+id/tv_budget_remaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            android:textSize="@dimen/sp_14"
                            android:textColor="@color/color_money"
                            app:noteBigDecimal="@{viewModel.monthBudget.remainingAmount}"
                            app:layout_constraintTop_toTopOf="@id/tv_budget_remining_amount"
                            app:layout_constraintBottom_toBottomOf="@id/tv_budget_remining_amount"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginRight="@dimen/dp_15"/>

                        <TextView
                            android:id="@+id/tv_budget_line"
                            android:layout_width="@dimen/dp_0"
                            android:layout_height="@dimen/dp_1"
                            app:layout_constraintTop_toBottomOf="@id/tv_budget_remining_amount"
                            app:layout_constraintStart_toEndOf="@id/percent_view"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginRight="@dimen/dp_15"
                            android:layout_marginLeft="@dimen/dp_15"
                            android:background="@color/color_app_main_bg"
                            android:layout_marginTop="@dimen/dp_7"/>

                        <TextView
                            android:id="@+id/tv_budget_total_amount_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toBottomOf="@id/tv_budget_line"
                            app:layout_constraintStart_toEndOf="@id/percent_view"
                            style="@style/AppTextTheme.Normal"
                            android:text="@string/budget_total_amount"
                            android:layout_marginLeft="@dimen/dp_15"
                            app:layout_constraintVertical_chainStyle="packed"
                            android:layout_marginBottom="@dimen/dp_2"
                            app:layout_constraintBottom_toTopOf="@id/tv_budget_used_amount_text"/>

                        <TextView
                            android:id="@+id/tv_budget_used_amount_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toBottomOf="@id/tv_budget_total_amount_text"
                            app:layout_constraintBottom_toBottomOf="@id/percent_view"
                            app:layout_constraintStart_toEndOf="@id/percent_view"
                            style="@style/AppTextTheme.Normal"
                            android:layout_marginTop="@dimen/dp_2"
                            app:layout_constraintVertical_chainStyle="packed"
                            android:layout_marginLeft="@dimen/dp_15"
                            android:layout_marginBottom="@dimen/dp_5"
                            android:text="@string/budget_used_amount"
                            android:textColor="@color/color_bill_expenditure"/>


                        <TextView
                            android:id="@+id/tv_budget_total_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            app:noteBigDecimal="@{viewModel.monthBudget.budgetAmount}"
                            app:layout_constraintTop_toTopOf="@id/tv_budget_total_amount_text"
                            app:layout_constraintBottom_toBottomOf="@id/tv_budget_total_amount_text"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginRight="@dimen/dp_15" />


                        <TextView
                            android:id="@+id/tv_budget_used_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/AppTextTheme.Normal"
                            app:noteBigDecimal="@{viewModel.monthBudget.usedAmount}"
                            app:layout_constraintTop_toTopOf="@id/tv_budget_used_amount_text"
                            app:layout_constraintBottom_toBottomOf="@id/tv_budget_used_amount_text"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginRight="@dimen/dp_15"
                            android:textColor="@color/color_bill_expenditure"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>


                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>
