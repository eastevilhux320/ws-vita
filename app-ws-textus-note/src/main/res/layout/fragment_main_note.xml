<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.wangshu.textus.note.model.main.note.NoteViewModel" />

        <variable
            name="fragment"
            type="com.wangshu.textus.note.model.main.note.NoteFragment" />

        <variable
            name="memoAdapter"
            type="com.wsvita.core.common.adapter.CoreAdapter" />

        <variable
            name="planAdapter"
            type="com.wangshu.textus.note.adapter.PlanAdapter" />

        <variable
            name="noteAdapter"
            type="com.wangshu.textus.note.adapter.NoteAdapter" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_note_title"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_80"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@color/color_main_theme"
            android:paddingTop="@dimen/dp_32">

            <TextView
                android:id="@+id/tv_week_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AppTextTheme.Normal"
                app:appText="@{viewModel.time.showWeekTime()}"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginLeft="@dimen/dp_15"
                android:textColor="@color/white"/>


            <TextView
                android:id="@+id/tv_temperature_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AppTextTheme.Normal"
                app:appText="@{viewModel.weather.temperatureText}"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginRight="@dimen/dp_15"
                android:textColor="@color/white"/>


            <ImageView
                android:id="@+id/iv_weather_icon"
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_25"
                app:srcUrl="@{viewModel.weather.weatherPic}"
                app:layout_constraintTop_toTopOf="@id/tv_temperature_text"
                app:layout_constraintBottom_toBottomOf="@id/tv_temperature_text"
                app:layout_constraintEnd_toStartOf="@id/tv_temperature_text"
                android:layout_marginRight="@dimen/dp_5"/>

            <TextView
                android:id="@+id/tv_note_city_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AppTextTheme.Normal"
                app:appText="@{viewModel.location.district}"
                app:layout_constraintTop_toTopOf="@id/tv_temperature_text"
                app:layout_constraintBottom_toBottomOf="@id/tv_temperature_text"
                app:layout_constraintEnd_toStartOf="@id/iv_weather_icon"
                android:layout_marginRight="@dimen/dp_10"
                android:textColor="@color/white"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refreshlayout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0"
            app:layout_constraintTop_toBottomOf="@id/cl_note_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/ll_main_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_10"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_day_ie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginRight="@dimen/dp_15"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/dp_10">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/iv_note_today_ie"
                                android:layout_width="@dimen/dp_30"
                                android:layout_height="@dimen/dp_30"
                                android:src="@drawable/ic_note_today_ie"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                android:padding="@dimen/dp_5"
                                android:layout_marginTop="@dimen/dp_10"
                                android:layout_marginLeft="@dimen/dp_10"/>

                            <TextView
                                android:id="@+id/tv_note_today_ie"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/AppTextTheme.Normal"
                                android:text="@string/note_today_ie"
                                app:layout_constraintTop_toTopOf="@id/iv_note_today_ie"
                                app:layout_constraintBottom_toBottomOf="@id/iv_note_today_ie"
                                app:layout_constraintStart_toEndOf="@id/iv_note_today_ie"
                                android:layout_marginLeft="@dimen/dp_10"/>


                            <TextView
                                android:id="@+id/tv_note_bill"
                                android:layout_width="@dimen/dp_70"
                                android:layout_height="@dimen/dp_30"
                                app:layout_constraintTop_toTopOf="@id/iv_note_today_ie"
                                app:layout_constraintBottom_toBottomOf="@id/iv_note_today_ie"
                                app:layout_constraintEnd_toEndOf="parent"
                                android:layout_marginRight="@dimen/dp_15"
                                android:background="@drawable/shape_fillet_maintheme_15"
                                android:text="@string/note_bill"
                                style="@style/AppTextTheme.Normal"
                                android:textColor="@color/white"
                                android:onClick="@{fragment.onViewClick}"/>


                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/cl_today_income"
                                android:layout_width="@dimen/dp_0"
                                android:layout_height="@dimen/dp_70"
                                app:layout_constraintTop_toBottomOf="@id/iv_note_today_ie"
                                android:layout_marginTop="@dimen/dp_10"
                                app:layout_constraintEnd_toStartOf="@id/cl_today_expenditure"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                android:layout_marginBottom="@dimen/dp_10">

                                <ImageView
                                    android:id="@+id/iv_today_income"
                                    android:layout_width="@dimen/dp_20"
                                    android:layout_height="@dimen/dp_20"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    android:src="@drawable/ic_ie_income"
                                    app:layout_constraintVertical_chainStyle="packed"
                                    app:layout_constraintHorizontal_chainStyle="packed"
                                    app:layout_constraintEnd_toStartOf="@id/tv_today_income_text"
                                    app:layout_constraintBottom_toTopOf="@id/tv_today_income"/>

                                <TextView
                                    android:id="@+id/tv_today_income_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:layout_constraintTop_toTopOf="@id/iv_today_income"
                                    app:layout_constraintBottom_toBottomOf="@id/iv_today_income"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    android:text="@string/note_today_income"
                                    app:layout_constraintHorizontal_chainStyle="packed"
                                    android:textColor="@color/color_bill_income"
                                    android:layout_marginLeft="@dimen/dp_5"
                                    app:layout_constraintVertical_chainStyle="packed"
                                    app:layout_constraintStart_toEndOf="@id/iv_today_income"/>

                                <TextView
                                    android:id="@+id/tv_today_income"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/AppTextTheme.Normal"
                                    android:text="@{viewModel.billingDetail.todayIncomeText}"
                                    android:textColor="@color/color_bill_income"
                                    android:textSize="@dimen/sp_18"
                                    app:layout_constraintTop_toBottomOf="@id/iv_today_income"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"/>

                            </androidx.constraintlayout.widget.ConstraintLayout>


                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/cl_today_expenditure"
                                android:layout_width="@dimen/dp_0"
                                android:layout_height="@dimen/dp_0"
                                app:layout_constraintTop_toTopOf="@id/cl_today_income"
                                app:layout_constraintBottom_toBottomOf="@id/cl_today_income"
                                app:layout_constraintEnd_toStartOf="@id/cl_today_balance"
                                app:layout_constraintStart_toEndOf="@id/cl_today_income">


                                <ImageView
                                    android:id="@+id/iv_today_expenditure"
                                    android:layout_width="@dimen/dp_20"
                                    android:layout_height="@dimen/dp_20"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    android:src="@drawable/ic_ie_expenditure"
                                    app:layout_constraintVertical_chainStyle="packed"
                                    app:layout_constraintHorizontal_chainStyle="packed"
                                    app:layout_constraintEnd_toStartOf="@id/tv_today_expenditure_text"
                                    app:layout_constraintBottom_toTopOf="@id/tv_today_expenditure"/>

                                <TextView
                                    android:id="@+id/tv_today_expenditure_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:layout_constraintTop_toTopOf="@id/iv_today_expenditure"
                                    app:layout_constraintBottom_toBottomOf="@id/iv_today_expenditure"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    android:text="@string/note_today_expenditure"
                                    app:layout_constraintHorizontal_chainStyle="packed"
                                    android:textColor="@color/color_bill_expenditure"
                                    android:layout_marginLeft="@dimen/dp_5"
                                    app:layout_constraintVertical_chainStyle="packed"
                                    app:layout_constraintStart_toEndOf="@id/iv_today_expenditure"/>

                                <TextView
                                    android:id="@+id/tv_today_expenditure"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/AppTextTheme.Normal"
                                    android:text="@{viewModel.billingDetail.todayExpenditureText}"
                                    android:textColor="@color/color_bill_expenditure"
                                    android:textSize="@dimen/sp_18"
                                    app:layout_constraintTop_toBottomOf="@id/iv_today_expenditure"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"/>

                            </androidx.constraintlayout.widget.ConstraintLayout>


                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/cl_today_balance"
                                android:layout_width="@dimen/dp_0"
                                android:layout_height="@dimen/dp_0"
                                app:layout_constraintTop_toTopOf="@id/cl_today_income"
                                app:layout_constraintBottom_toBottomOf="@id/cl_today_income"
                                app:layout_constraintStart_toEndOf="@id/cl_today_expenditure"
                                app:layout_constraintEnd_toEndOf="parent">

                                <ImageView
                                    android:id="@+id/iv_today_balance"
                                    android:layout_width="@dimen/dp_20"
                                    android:layout_height="@dimen/dp_20"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    android:src="@drawable/ic_ie_balance"
                                    app:layout_constraintVertical_chainStyle="packed"
                                    app:layout_constraintHorizontal_chainStyle="packed"
                                    app:layout_constraintEnd_toStartOf="@id/tv_today_balance_text"
                                    app:layout_constraintBottom_toTopOf="@id/tv_today_balance"/>

                                <TextView
                                    android:id="@+id/tv_today_balance_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:layout_constraintTop_toTopOf="@id/iv_today_balance"
                                    app:layout_constraintBottom_toBottomOf="@id/iv_today_balance"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    android:text="@string/note_today_balance"
                                    app:layout_constraintHorizontal_chainStyle="packed"
                                    android:textColor="@color/color_main_theme"
                                    android:layout_marginLeft="@dimen/dp_5"
                                    app:layout_constraintVertical_chainStyle="packed"
                                    app:layout_constraintStart_toEndOf="@id/iv_today_balance"/>

                                <TextView
                                    android:id="@+id/tv_today_balance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/AppTextTheme.Normal"
                                    app:appText="@{viewModel.billingDetail.todayBalanceText}"
                                    android:textColor="@color/color_main_theme"
                                    android:textSize="@dimen/sp_18"
                                    app:layout_constraintTop_toBottomOf="@id/iv_today_balance"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"/>

                            </androidx.constraintlayout.widget.ConstraintLayout>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginRight="@dimen/dp_15"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/dp_10">


                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/cl_note_memo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/iv_note_note_memo"
                                android:layout_width="@dimen/dp_30"
                                android:layout_height="@dimen/dp_30"
                                android:src="@drawable/ic_note_note_memo"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                android:padding="@dimen/dp_5"
                                android:layout_marginTop="@dimen/dp_10"
                                android:layout_marginLeft="@dimen/dp_10"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/AppTextTheme.Normal"
                                android:text="@string/note_memo_tips"
                                app:layout_constraintTop_toTopOf="@id/iv_note_note_memo"
                                app:layout_constraintBottom_toBottomOf="@id/iv_note_note_memo"
                                app:layout_constraintStart_toEndOf="@id/iv_note_note_memo"
                                android:layout_marginLeft="@dimen/dp_5"
                                android:textColor="@color/color_note_memo"/>


                            <LinearLayout
                                android:id="@+id/ll_note_memo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="@id/iv_note_note_memo"
                                app:layout_constraintBottom_toBottomOf="@id/iv_note_note_memo"
                                app:layout_constraintEnd_toEndOf="parent"
                                android:layout_marginRight="@dimen/dp_10"
                                android:gravity="center_vertical"
                                android:onClick="@{fragment.onViewClick}">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/AppTextTheme.Normal"
                                    android:text="@string/note_memo"
                                    android:textColor="@color/color_note_memo"
                                    android:layout_marginRight="@dimen/dp_5"/>

                                <ImageView
                                    android:layout_width="@dimen/dp_13"
                                    android:layout_height="@dimen/dp_13"
                                    android:src="@drawable/ic_note_memo"/>

                            </LinearLayout>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_memo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toBottomOf="@id/iv_note_note_memo"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:adapter="@{memoAdapter}"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                app:appVisibility="@{viewModel.memoList.size() > 0}"/>

                            <com.wsvita.ui.view.EmptyView
                                android:id="@+id/empty_note"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/empty_view_height"
                                app:layout_constraintTop_toBottomOf="@id/rv_memo"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:empty_src="@drawable/ic_empty_default"
                                app:empty_text="@string/empty_note_list"
                                app:appVisibility="@{viewModel.memoList.size() &lt;= 0}"/>


                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_note_plan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginRight="@dimen/dp_15"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/dp_10">


                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/cl_note_plan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/iv_note_note_plan"
                                android:layout_width="@dimen/dp_30"
                                android:layout_height="@dimen/dp_30"
                                android:src="@drawable/ic_note_note_plan"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                android:padding="@dimen/dp_5"
                                android:layout_marginTop="@dimen/dp_10"
                                android:layout_marginLeft="@dimen/dp_10"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/AppTextTheme.Normal"
                                android:text="@string/note_plan_tips"
                                app:layout_constraintTop_toTopOf="@id/iv_note_note_plan"
                                app:layout_constraintBottom_toBottomOf="@id/iv_note_note_plan"
                                app:layout_constraintStart_toEndOf="@id/iv_note_note_plan"
                                android:layout_marginLeft="@dimen/dp_5"
                                android:textColor="@color/color_note_plan"/>


                            <LinearLayout
                                android:id="@+id/ll_note_plan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="@id/iv_note_note_plan"
                                app:layout_constraintBottom_toBottomOf="@id/iv_note_note_plan"
                                app:layout_constraintEnd_toEndOf="parent"
                                android:layout_marginRight="@dimen/dp_10"
                                android:gravity="center_vertical"
                                android:onClick="@{fragment.onViewClick}">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/AppTextTheme.Normal"
                                    android:text="@string/note_plan"
                                    android:textColor="@color/color_note_plan"
                                    android:layout_marginRight="@dimen/dp_5"/>

                                <ImageView
                                    android:layout_width="@dimen/dp_13"
                                    android:layout_height="@dimen/dp_13"
                                    android:src="@drawable/ic_note_memo"/>

                            </LinearLayout>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_plan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toBottomOf="@id/iv_note_note_plan"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:adapter="@{planAdapter}"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                android:visibility="@{viewModel.planList.size > 0}"/>


                            <com.wsvita.ui.view.EmptyView
                                android:id="@+id/empty_plan"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/empty_view_height"
                                app:layout_constraintTop_toBottomOf="@id/iv_note_note_plan"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:empty_src="@drawable/ic_empty_default"
                                app:empty_text="@string/empty_plan_list"
                                android:layout_marginTop="@dimen/dp_5"
                                android:visibility="@{viewModel.planList.size() &lt;= 0}"/>

                        </androidx.constraintlayout.widget.ConstraintLayout>


                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_note_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp"
                        android:layout_marginLeft="@dimen/dp_15"
                        android:layout_marginRight="@dimen/dp_15"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/dp_10">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_fillet_white_8">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_note"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                android:layout_marginTop="@dimen/dp_10"
                                app:adapter="@{noteAdapter}"
                                android:visibility="@{viewModel.noteList.size() > 0}"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/cl_empty_note_view"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                android:visibility="@{viewModel.noteList.size() &lt;= 0}">

                                <ImageView
                                    android:id="@+id/iv_note_note_note"
                                    android:layout_width="@dimen/dp_30"
                                    android:layout_height="@dimen/dp_30"
                                    android:src="@drawable/ic_note_note_note"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    android:padding="@dimen/dp_5"
                                    android:layout_marginTop="@dimen/dp_10"
                                    android:layout_marginLeft="@dimen/dp_10"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/AppTextTheme.Normal"
                                    app:appText="@{viewModel.noteTimeText}"
                                    app:layout_constraintTop_toTopOf="@id/iv_note_note_note"
                                    app:layout_constraintBottom_toBottomOf="@id/iv_note_note_note"
                                    app:layout_constraintStart_toEndOf="@id/iv_note_note_note"
                                    android:layout_marginLeft="@dimen/dp_5"/>

                                <LinearLayout
                                    android:id="@+id/ll_note_note"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:layout_constraintTop_toTopOf="@id/iv_note_note_note"
                                    app:layout_constraintBottom_toBottomOf="@id/iv_note_note_note"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    android:layout_marginRight="@dimen/dp_10"
                                    android:gravity="center_vertical"
                                    android:onClick="@{fragment.onViewClick}">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        style="@style/AppTextTheme.Normal"
                                        android:text="@string/note_note"
                                        android:textColor="@color/color_main_theme"
                                        android:layout_marginRight="@dimen/dp_5"/>

                                    <ImageView
                                        android:layout_width="@dimen/dp_13"
                                        android:layout_height="@dimen/dp_13"
                                        android:src="@drawable/ic_note_note"/>

                                </LinearLayout>

                                <com.wsvita.ui.view.EmptyView
                                    android:id="@+id/empty_note_note"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/empty_view_height"
                                    app:layout_constraintTop_toBottomOf="@id/iv_note_note_note"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:empty_src="@drawable/ic_empty_default"
                                    app:empty_text="@string/empty_note_list" />

                            </androidx.constraintlayout.widget.ConstraintLayout>


                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.cardview.widget.CardView>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_50"/>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>


        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>



</layout>
