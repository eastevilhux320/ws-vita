<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="noteText"
            type="com.wangshu.textus.note.entity.note.NoteTextEntity" />

        <variable
            name="position"
            type="Integer" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingBottom="@dimen/dp_10">

        <TextView
            android:id="@+id/tv_note_position"
            android:layout_width="@dimen/dp_15"
            android:layout_height="@dimen/dp_15"
            android:text="@{position.toString()}"
            android:textSize="@dimen/sp_9"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="@dimen/dp_10"
            android:layout_marginLeft="@dimen/dp_15"
            android:textColor="@color/base_app_text"
            style="@style/AppTextTheme.Normal"
            android:background="@drawable/bg_ic_note_index"/>

        <TextView
            android:id="@+id/tv_note_text"
            android:layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_note_position"
            android:layout_marginLeft="@dimen/dp_8"
            android:layout_marginTop="@dimen/dp_8"
            app:layout_constraintEnd_toStartOf="@id/iv_note_weather"
            style="@style/AppTextTheme.Normal"
            android:layout_marginRight="@dimen/dp_8"
            android:textSize="@dimen/sp_12"
            android:gravity="left"
            android:text="@{noteText.text}"/>

        <ImageView
            android:id="@+id/iv_note_weather"
            android:layout_width="@dimen/dp_25"
            android:layout_height="@dimen/dp_25"
            style="@style/AppTextTheme.Normal"
            android:src="@{noteText.weatherPic}"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_note_city"
            android:layout_marginRight="@dimen/dp_15"/>

        <TextView
            android:id="@+id/tv_note_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Normal"
            android:textSize="@dimen/sp_12"
            app:layout_constraintTop_toBottomOf="@id/iv_note_weather"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/iv_note_weather"
            android:text="@{noteText.city}"/>

        <TextView
            android:id="@+id/tv_note_createtime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Normal"
            app:layout_constraintTop_toBottomOf="@id/tv_note_text"
            app:layout_constraintStart_toEndOf="@id/tv_note_position"
            android:textSize="@dimen/sp_12"
            android:textColor="@color/starColorHint"
            android:layout_marginLeft="@dimen/dp_8"
            android:text="@{noteText.createTimeText}"
            android:layout_marginTop="@dimen/dp_7" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
