<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="billType"
            type="com.wangshu.textus.note.entity.bill.BillTypeEntity" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:background="@drawable/selecter_list_item_default">

        <ImageView
            android:id="@+id/iv_billtype_icon"
            android:layout_width="@dimen/dp_25"
            android:layout_height="@dimen/dp_25"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginLeft="@dimen/dp_15"
            android:src="@{billType.iconUrl}"/>

        <TextView
            android:id="@+id/tv_billtype_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Normal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_billtype_icon"
            android:layout_marginLeft="@dimen/dp_15"
            android:text="@{billType.typeName}"/>

        <ImageView
            android:id="@+id/iv_bill_type_arrow"
            android:layout_width="@dimen/ws_arrow_img_size"
            android:layout_height="@dimen/ws_arrow_img_size"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:src="@drawable/wsui_ic_va_arrow_gray"
            android:layout_marginRight="@dimen/dp_15"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
