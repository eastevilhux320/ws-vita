<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="noteText"
            type="com.wangshu.textus.note.entity.note.NoteTextEntity" />

        <variable
            name="position"
            type="Integer" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingBottom="@dimen/dp_15">

        <TextView
            android:id="@+id/tv_note_index"
            android:layout_width="@dimen/dp_15"
            android:layout_height="@dimen/dp_15"
            android:background="@drawable/bg_ic_note_index"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:textSize="@dimen/sp_11"
            android:layout_marginTop="@dimen/dp_10"
            android:layout_marginLeft="@dimen/dp_15"
            style="@style/AppTextTheme.Normal"
            android:text="@{position+1}"/>


        <ImageView
            android:id="@+id/iv_notetext_save"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:padding="@dimen/dp_5"
            android:src="@drawable/icon_notetext_save"
            app:layout_constraintTop_toTopOf="@id/tv_note_index"
            app:layout_constraintBottom_toBottomOf="@id/tv_note_index"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginRight="@dimen/dp_15"
            android:visibility="@{noteText.isEditing &amp;&amp; noteText.isInput}"/>

        <EditText
            android:id="@+id/edit_note_text"
            android:layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/tv_note_index"
            app:layout_constraintStart_toEndOf="@id/tv_note_index"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginLeft="@dimen/dp_10"
            android:layout_marginRight="@dimen/dp_8"
            style="@style/AppEditText.Left"
            android:gravity="top|left"
            android:minHeight="@dimen/dp_80"
            app:layout_constraintEnd_toStartOf="@id/iv_notetext_save"
            android:hint="@string/hint_note_content"
            android:visibility="@{noteText.isInput}" />

        <TextView
            android:id="@+id/tv_note_text"
            android:layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/tv_note_index"
            app:layout_constraintStart_toEndOf="@id/tv_note_index"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginLeft="@dimen/dp_10"
            android:layout_marginRight="@dimen/dp_8"
            style="@style/AppTextTheme.Normal"
            android:gravity="top|left"
            android:text="@{noteText.text}"
            android:visibility="@{!noteText.isInput}"
            app:layout_constraintEnd_toStartOf="@id/iv_note_weather"/>

        <TextView
            android:id="@+id/tv_notetext_time"
            android:layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            style="@style/AppTextTheme.Normal"
            app:layout_constraintTop_toBottomOf="@id/tv_note_text"
            app:layout_constraintStart_toStartOf="@id/tv_note_text"
            android:gravity="left|top"
            android:layout_marginRight="@dimen/dp_8"
            android:textColor="@color/starColorHint"
            android:text="@{noteText.createTimeText}"
            android:visibility="@{!noteText.isInput}"
            android:textSize="@dimen/sp_11"/>


        <ImageView
            android:id="@+id/iv_note_weather"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            app:layout_constraintTop_toTopOf="@id/tv_note_index"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginRight="@dimen/dp_15"
            android:src="@{noteText.weatherPic}"/>

        <TextView
            android:id="@+id/tv_note_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/iv_note_weather"
            app:layout_constraintStart_toStartOf="@id/iv_note_weather"
            app:layout_constraintEnd_toEndOf="@id/iv_note_weather"
            android:text="@{noteText.weather}"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
